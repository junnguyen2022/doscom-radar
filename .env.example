# Anthropic
ANTHROPIC_API_KEY=

# OpenAI — fallback khi Anthropic lỗi/hết credit (tùy chọn). OPENAI_MODEL mặc định gpt-4o-mini.
OPENAI_API_KEY=
OPENAI_MODEL=

# Webhook nhận bản tin brand hằng tuần (Lark custom bot hoặc Slack incoming webhook). Tùy chọn.
DIGEST_WEBHOOK_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direct connection (for MCP)
DATABASE_URL=

# GitHub (for MCP, optional)
GITHUB_TOKEN=

# Cron auth — Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}`
CRON_SECRET=
